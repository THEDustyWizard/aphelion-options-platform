{
  "name": "aphelion-backend",
  "version": "1.0.0",
  "description": "APHELION Options Trading Platform Backend - Node.js/TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "docker:build": "docker build -t aphelion-backend .",
    "docker:run": "docker run -p 3000:3000 aphelion-backend"
  },
  "keywords": [
    "options-trading",
    "finance",
    "quantitative-analysis",
    "nodejs",
    "typescript"
  ],
  "author": "APHELION Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "joi": "^17.9.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.1",
    "redis": "^4.6.8",
    "pg": "^8.11.3",
    "typeorm": "^0.3.17",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.6.1",
    "axios": "^1.5.0",
    "node-cron": "^3.0.2",
    "yfinance": "^0.0.6",
    "bull": "^4.11.2",
    "prom-client": "^14.2.0",
    "swagger-ui-express": "^4.6.3",
    "swagger-jsdoc": "^6.2.8",
    "rate-limiter-flexible": "^9.1.1",
    "node-fetch": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.5.7",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/helmet": "^4.0.0",
    "@types/compression": "^1.7.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/joi": "^17.2.3",
    "@types/node-cron": "^3.0.8",
    "@types/swagger-ui-express": "^4.1.3",
    "typescript": "^5.2.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.6.4",
    "@types/jest": "^29.5.4",
    "ts-jest": "^29.1.1",
    "eslint": "^8.48.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "prettier": "^3.0.2",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}